# App Config
NODE_ENV=
PORT=

# CORS Config
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_VERCEL_PREVIEWS=false

# Database Config
DATABASE_URL=your_database_url
DIRECT_URL=your_database_direct_url

# JWT Config
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=your_jwt_expires_in

# Upstash Redis
UPSTASH_REDIS_URL=your_upstash_redis_tcp_url

# Product Config
FRESHNESS_WINDOW_DAYS=
FLAG_MARK_THRESHOLD=
FLAG_EXCLUDE_THRESHOLD=

# Seed script
SEED_ADMIN_PASSWORD=
SEED_CONTRIB_PASSWORD=