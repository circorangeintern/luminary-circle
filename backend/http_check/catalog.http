@base = https://staging.marketcompare.name.ng/api/v1

### Get all active items
GET {{base}}/items

### Get all active markets
GET {{base}}/markets

@riceId = cmrmtby0c000apwdjuuy3cixh
@dericaId = cmrmtbv820000pwdjwt3ouvbi
@tomatoId = cmrmtbybo000cpwdjfek4ljjl
@basketId = cmrmtbxuj0009pwdjod0sizrl
@eggsId = cmrmtbyn0000epwdj81z5j7sm
@crateId = cmrmtbx7u0004pwdjafjbl4ae
@bagId = cmrmtbx0x0003pwdjra33zskz
@oilId = cmrmtbyha000dpwdjzg2d06rj
@kegId = cmrmtbxpp0008pwdj6iuv483a
@muduId = cmrmtbwth0001pwdjqht84eqi
@beansId = cmrmtby5z000bpwdjonxn47hj
